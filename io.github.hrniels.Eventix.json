{
    "app-id": "io.github.hrniels.Eventix",
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.rust-stable",
        "org.freedesktop.Sdk.Extension.openjdk"
    ],
    "command": "eventix-app",
    "finish-args": [
        "--share=network",
        "--share=ipc",
        "--device=dri",
        "--socket=x11",
        "--socket=session-bus",
        "--env=PATH=/app/jre/bin:/app/bin:/usr/bin"
    ],
    "build-options": {
        "append-path": "/usr/lib/sdk/rust-stable/bin",
        "env": {
            "CARGO_HOME": "/run/build/Eventix/cargo",
            "CARGO_NET_OFFLINE": "true"
        }
    },
    "modules": [
        "python-sources.json",
        {
            "name": "vdirsyncer",
            "buildsystem": "simple",
            "build-commands": [
                "pip3 install --no-index --find-links=. --prefix=/app --no-build-isolation .",
                "install -Dm644 LICENSE -t /app/share/licenses/io.github.hrniels.Eventix/vdirsyncer"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/hrniels/vdirsyncer.git",
                    "commit": "a83fc9641fb1914e0a9af2f3339961cc7a126f26",
                    "disable-submodules": true
                }
            ]
        },
        {
            "name": "openjdk",
            "buildsystem": "simple",
            "build-commands": [
                "/usr/lib/sdk/openjdk/install.sh"
            ]
        },
        {
            "name": "davmail",
            "buildsystem": "simple",
            "build-options": {
                "env": {
                    "JAVA_HOME": "/usr/lib/sdk/openjdk",
                    "PATH": "/usr/lib/sdk/openjdk/bin:/app/bin:/usr/bin"
                }
            },
            "build-commands": [
                "mvn --offline install -Dmaven.repo.local=flatpak/java-deps",
                "ant prepare-dist",
                "install -Dm755 dist/davmail /app/bin/davmail",
                "install -D dist/davmail.jar /app/bin/davmail.jar",
                "mkdir -p /app/bin/lib",
                "cp dist/lib/* /app/bin/lib",
                "install -Dm644 LICENSE -t /app/share/licenses/io.github.hrniels.Eventix/davmail"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/hrniels/davmail.git",
                    "commit": "3a4751992a44e1c36370ddd525fad8c8534e4239",
                    "disable-submodules": true
                },
                "java-sources.json"
            ]
        },
        {
            "name": "Eventix",
            "buildsystem": "simple",
            "build-commands": [
                "cargo build --release",
                "install -Dm755 target/release/eventix -t /app/bin/",
                "install -Dm755 target/release/eventix-app -t /app/bin/",
                "install -Dm755 target/release/eventix-import -t /app/bin/",
                "install -Dm755 target/release/eventix-keyring -t /app/bin/",
                "install -Dm644 flatpak/io.github.hrniels.Eventix.desktop -t /app/share/applications/",
                "install -Dm644 flatpak/io.github.hrniels.Eventix-Import.desktop -t /app/share/applications/",
                "install -Dm644 data/icons/scalable.svg /app/share/icons/hicolor/scalable/apps/io.github.hrniels.Eventix.svg",
                "install -Dm644 data/icons/256x256.png /app/share/icons/hicolor/256x256/apps/io.github.hrniels.Eventix.png",
                "install -Dm644 data/icons/128x128.png /app/share/icons/hicolor/128x128/apps/io.github.hrniels.Eventix.png",
                "install -Dm644 data/icons/64x64.png /app/share/icons/hicolor/64x64/apps/io.github.hrniels.Eventix.png",
                "install -Dm644 data/icons/48x48.png /app/share/icons/hicolor/48x48/apps/io.github.hrniels.Eventix.png",
                "install -Dm644 data/icons/index.theme /app/share/icons/hicolor/index.theme",
                "install -Dm644 flatpak/io.github.hrniels.Eventix.metainfo.xml -t /app/share/metainfo/",
                "install -Dm644 LICENSE -t /app/share/licenses/io.github.hrniels.Eventix/eventix",
                "mkdir -p /app/share/io.github.hrniels.Eventix/locale",
                "mkdir -p /app/share/io.github.hrniels.Eventix/static",
                "mkdir -p /app/share/io.github.hrniels.Eventix/icons",
                "cp -r data/locale /app/share/io.github.hrniels.Eventix",
                "cp -r data/static /app/share/io.github.hrniels.Eventix",
                "cp -r data/icons /app/share/io.github.hrniels.Eventix"
            ],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/hrniels/eventix.git",
                    "commit": "746c1e3ba4d2e3c4a85b20d42c4a0887fb4e24c6",
                    "tag": "v1.0.5",
                    "disable-submodules": true
                },
                "cargo-sources.json"
            ]
        }
    ]
}
